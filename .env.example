PORT=5000
FRONTEND_URL=http://localhost:5173
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/aichat

# Admin panel credentials — set these before first boot.
# The admin logs in at /admin with these, not with an access code.
ADMIN_NAME=Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose_a_strong_password_here

# API Keys (leave empty to trigger backend Mock Mode fallbacks)
#
# Gemini: use ONE key from ONE Google Cloud project. Quota is pooled per
# project, not per key — multiple keys/projects risk Google abuse detection.
# Enable billing on this one project (Tier 1) if you need more throughput.
GEMINI_API_KEY=

GROQ_API_KEY=
OPENROUTER_API_KEY=
COHERE_API_KEY=
MISTRAL_API_KEY=
HUGGINGFACE_API_KEY=
TAVILY_API_KEY=
